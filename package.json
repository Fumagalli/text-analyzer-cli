{
  "name": "text-analyzer-cli",
  "version": "1.0.0",
  "description": "CLI tool to analyze text and find duplicate words in paragraphs",
  "main": "src/index.ts",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "text-analyzer-cli": "dist/cli.js"
  },
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "cli": "node --loader ts-node/esm src/cli.ts"
  },
  "keywords": [
    "cli",
    "text-analysis",
    "word-count",
    "nodejs",
    "typescript"
  ],
  "author": "Fumagalli",
  "license": "MIT",
  "repository": "git@github.com:Fumagalli/text-analyzer-cli.git",
  "type": "module",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/chalk": "^2.2.4",
    "@types/commander": "^2.12.5",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  }
}
